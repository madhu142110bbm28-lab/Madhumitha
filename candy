from typing import List

class Solution:
    def candy(self, ratings: List[int]) -> int:
        n = len(ratings)
        # 1. Start by giving every child at least 1 candy
        candies = [1] * n
        
        # 2. Left-to-Right Pass:
        # If the current child has a higher rating than the left neighbour,
        # they must have more candy than the left neighbour.
        for i in range(1, n):
            if ratings[i] > ratings[i - 1]:
                candies[i] = candies[i - 1] + 1
        
        # 3. Right-to-Left Pass:
        # If the current child has a higher rating than the right neighbour,
        # they must have more candy than the right neighbour.
        # We use max() to satisfy both left and right constraints.
        for i in range(n - 2, -1, -1):
            if ratings[i] > ratings[i + 1]:
                candies[i] = max(candies[i], candies[i + 1] + 1)
        
        # 4. Total candies is the sum of the array
        return sum(candies)
        

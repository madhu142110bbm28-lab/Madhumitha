class Solution:
    def isNumber(self, s: str) -> bool:
        # State tracking flags
        seen_digit = seen_dot = seen_exponent = False
        
        for i, char in enumerate(s):
            if char.isdigit():
                seen_digit = True
            elif char in "+-":
                # Sign must be at start or immediately after 'e'/'E'
                if i > 0 and s[i-1] not in "eE":
                    return False
            elif char in "eE":
                # Exponent only allowed once and after at least one digit
                if seen_exponent or not seen_digit:
                    return False
                seen_exponent = True
                seen_digit = False  # Reset for digits required after 'e'
            elif char == ".":
                # Dot only allowed once and NOT after an exponent
                if seen_dot or seen_exponent:
                    return False
                seen_dot = True
            else:
                # Any other character is invalid
                return False
        
        # Must end with a digit (handles cases like "1e", "+", or ".")
        return seen_digit

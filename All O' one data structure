class Node:
    def __init__(self, count):
        self.count = count
        self.keys = set()
        self.prev = None
        self.next = None

class AllOne:
    def __init__(self):
        # Maps key to its current count Node
        self.mapping = {}
        # Sentinel head and tail for the frequency list
        self.head = Node(0)
        self.tail = Node(0)
        self.head.next = self.tail
        self.tail.prev = self.head

    def _insert_after(self, prev_node, new_node):
        new_node.prev = prev_node
        new_node.next = prev_node.next
        prev_node.next.prev = new_node
        prev_node.next = new_node

    def _remove_node(self, node):
        node.prev.next = node.next
        node.next.prev = node.prev

    def inc(self, key: str) -> None:
        if key not in self.mapping:
            # Case: New key, should go to frequency 1 bucket
            if self.head.next.count != 1:
                self._insert_after(self.head, Node(1))
            self.head.next.keys.add(key)
            self.mapping[key] = self.head.next
        else:
            # Case: Move from count n to n + 1
            curr = self.mapping[key]
            if curr.next.count != curr.count + 1:
                self._insert_after(curr, Node(curr.count + 1))
            curr.next.keys.add(key)
            self.mapping[key] = curr.next
            curr.keys.remove(key)
            if not curr.keys: self._remove_node(curr)

    def dec(self, key: str) -> None:
        curr = self.mapping[key]
        if curr.count == 1:
            del self.mapping[key]
        else:
            # Case: Move from count n to n - 1
            if curr.prev.count != curr.count - 1:
                self._insert_after(curr.prev, Node(curr.count - 1))
            curr.prev.keys.add(key)
            self.mapping[key] = curr.prev
        
        curr.keys.remove(key)
        if not curr.keys: self._remove_node(curr)

    def getMaxKey(self) -> str:
        if self.tail.prev == self.head: return ""
        # Return any key from the bucket with the highest count
        return next(iter(self.tail.prev.keys))

    def getMinKey(self) -> str:
        if self.head.next == self.tail: return ""
        # Return any key from the bucket with the lowest count
        return next(iter(self.head.next.keys))


